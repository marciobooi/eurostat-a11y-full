#!/usr/bin/env sh

# Block committing generated/dependency files and very large files.
# Works with Git for Windows (sh hook).

set -eu

MAX_SIZE_BYTES=50000000
BLOCKED_PREFIXES='node_modules/ dist/ dist-release/ build/'

staged_files=$(git diff --cached --name-only --diff-filter=ACMR)

# Nothing staged, nothing to validate.
[ -z "$staged_files" ] && exit 0

blocked_found=0
large_found=0

echo "$staged_files" | while IFS= read -r file; do
  [ -z "$file" ] && continue

  for prefix in $BLOCKED_PREFIXES; do
    case "$file" in
      "$prefix"*)
        if [ "$blocked_found" -eq 0 ]; then
          echo ""
          echo "ERROR: generated/dependency paths are blocked from commits:"
          blocked_found=1
        fi
        echo "  - $file"
        ;;
    esac
  done

  # Check staged blob size in index (not working tree file size).
  size=$(git cat-file -s ":$file" 2>/dev/null || echo 0)
  if [ "$size" -gt "$MAX_SIZE_BYTES" ]; then
    if [ "$large_found" -eq 0 ]; then
      echo ""
      echo "ERROR: staged files larger than 50 MB are blocked:"
      large_found=1
    fi
    echo "  - $file ($(awk "BEGIN { printf \"%.2f\", $size/1024/1024 }") MB)"
  fi
done

# Recompute flags in POSIX-safe way (pipeline runs in subshell above).
blocked_list=$(echo "$staged_files" | grep -E '^(node_modules/|dist/|dist-release/|build/)' || true)
large_list=''
for f in $staged_files; do
  s=$(git cat-file -s ":$f" 2>/dev/null || echo 0)
  if [ "$s" -gt "$MAX_SIZE_BYTES" ]; then
    large_list="${large_list}${f}\n"
  fi
done

if [ -n "$blocked_list" ] || [ -n "$large_list" ]; then
  echo ""
  echo "Commit blocked by pre-commit policy."
  echo "Fix: remove generated files from staging, or increase policy if truly needed."
  echo "To bypass once (not recommended): git commit --no-verify"
  exit 1
fi

exit 0
